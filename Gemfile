source "https://rubygems.org"

# Mirrors the gems GitHub Pages runs, so a local `bundle exec jekyll serve`
# matches what gets deployed. You only need this for local previews.
gem "github-pages", group: :jekyll_plugins

# Lock to a Ruby >= 3.0 friendly webrick (removed from stdlib in Ruby 3).
gem "webrick", "~> 1.8"
